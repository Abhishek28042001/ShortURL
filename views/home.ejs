<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>URL Shortener</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif; background: #f0f4f8; color: #1a202c; min-height: 100vh; }
      nav { background: #2563eb; color: #fff; padding: 0 2rem; height: 60px; display: flex; align-items: center; justify-content: space-between; box-shadow: 0 2px 8px rgba(37,99,235,.35); }
      nav .brand { font-size: 1.3rem; font-weight: 700; }
      nav .brand span { color: #93c5fd; }
      nav a.logout-btn { text-decoration: none; background: rgba(255,255,255,.15); color: #fff; padding: .4rem 1rem; border-radius: 6px; font-size: .88rem; }
      nav a.logout-btn:hover { background: rgba(255,255,255,.28); }
      main { max-width: 820px; margin: 2.5rem auto; padding: 0 1rem; }
      .card { background: #fff; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,.08); padding: 2rem; margin-bottom: 1.8rem; }
      .card h2 { font-size: 1.1rem; font-weight: 600; color: #374151; margin-bottom: 1.2rem; }
      .input-row { display: flex; gap: .75rem; }
      .input-row input { flex: 1; padding: .65rem 1rem; border: 1.5px solid #d1d5db; border-radius: 8px; font-size: .95rem; outline: none; }
      .input-row input:focus { border-color: #2563eb; }
      .input-row button { padding: .65rem 1.4rem; background: #2563eb; color: #fff; border: none; border-radius: 8px; font-size: .95rem; font-weight: 600; cursor: pointer; }
      .input-row button:hover { background: #1d4ed8; }
      .alert { margin-top: 1.1rem; padding: .85rem 1rem; background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 8px; display: flex; align-items: center; gap: .75rem; font-size: .92rem; color: #1e40af; flex-wrap: wrap; }
      .alert .label { font-weight: 600; }
      .alert a { color: #2563eb; word-break: break-all; }
      .copy-btn { margin-left: auto; padding: .3rem .8rem; background: #2563eb; color: #fff; border: none; border-radius: 6px; font-size: .8rem; cursor: pointer; }
      .table-wrap { overflow-x: auto; }
      table { width: 100%; border-collapse: collapse; font-size: .9rem; }
      thead tr { background: #f1f5f9; color: #475569; }
      th, td { padding: .75rem 1rem; text-align: left; border-bottom: 1px solid #e2e8f0; }
      th { font-weight: 600; font-size: .82rem; text-transform: uppercase; letter-spacing: .05em; }
      tbody tr:hover { background: #f8fafc; }
      td a { color: #2563eb; text-decoration: none; }
      td a:hover { text-decoration: underline; }
      .badge { display: inline-block; padding: .2rem .6rem; background: #dbeafe; color: #1e40af; border-radius: 9999px; font-size: .78rem; font-weight: 600; }
      .empty { text-align: center; padding: 2.5rem 0; color: #94a3b8; font-size: .95rem; }
    </style>
  </head>
  <body>
    <nav>
      <div class="brand">Short<span>URL</span></div>
      <a href="/user/logout" class="logout-btn">Logout</a>
    </nav>
    <main>
      <div class="card">
        <h2>Shorten a URL</h2>
        <form method="POST" action="/url">
          <div class="input-row">
            <input type="text" name="url" placeholder="https://example.com/your-long-url" required />
            <button type="submit">Shorten</button>
          </div>
        </form>
        <% if (locals.id) { %>
        <div class="alert">
          <span class="label">Short URL:</span>
          <a href="http://localhost:8001/url/<%= id %>" target="_blank">http://localhost:8001/url/<%= id %></a>
          <button class="copy-btn" onclick="navigator.clipboard.writeText('http://localhost:8001/url/<%= id %>');this.textContent='Copied!'">Copy</button>
        </div>
        <% } %>
      </div>
      <div class="card">
        <h2>Your Shortened URLs</h2>
        <div class="table-wrap">
          <% if (locals.urls && urls.length > 0) { %>
          <table>
            <thead>
              <tr><th>#</th><th>Short ID</th><th>Original URL</th><th>Clicks</th></tr>
            </thead>
            <tbody>
              <% urls.forEach((url, index) => { %>
              <tr>
                <td><%= index + 1 %></td>
                <td><a href="/url/<%= url.shortId %>" target="_blank"><%= url.shortId %></a></td>
                <td style="max-width:350px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                  <a href="<%= url.redirectURL %>" target="_blank" title="<%= url.redirectURL %>"><%= url.redirectURL %></a>
                </td>
                <td><span class="badge"><%= url.visitHistory.length %></span></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
          <% } else { %>
          <p class="empty">No URLs yet. Shorten your first URL above!</p>
          <% } %>
        </div>
      </div>
    </main>
  </body>
</html>